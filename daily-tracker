<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif;background:#f5f5f7;color:#1d1d1f;min-height:100vh}
#root{max-width:500px;margin:0 auto}

/* Common */
.card{background:#fff;border-radius:14px;padding:16px;margin-bottom:12px;box-shadow:0 1px 4px rgba(0,0,0,.06)}
.card-t{font-size:10px;color:#86868b;text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;font-weight:700}
.btn{width:100%;border:none;border-radius:12px;padding:14px;font-size:15px;font-weight:700;cursor:pointer;color:#fff}
.btn:active{opacity:.85}
.btn:disabled{opacity:.5}
.btn-purple{background:linear-gradient(135deg,#6C5CE7,#a78bfa)}
.btn-green{background:linear-gradient(135deg,#34C759,#30B350)}
.btn-small{padding:10px 16px;font-size:13px;width:auto;border-radius:10px}
input,select,textarea{width:100%;font-size:14px;padding:11px 14px;border:1.5px solid #d1d1d6;border-radius:10px;background:#f5f5f7;color:#1d1d1f;font-family:inherit}
input:focus,select:focus,textarea:focus{border-color:#6C5CE7;outline:none;background:#fff}
textarea{resize:vertical;min-height:50px}
input::placeholder,textarea::placeholder{color:#aeaeb2}
label{font-size:12px;color:#86868b;font-weight:600;display:block;margin-bottom:4px;margin-top:12px}
.toast{position:fixed;top:20px;left:50%;transform:translateX(-50%);background:#1d1d1f;color:#fff;padding:12px 24px;border-radius:12px;font-size:14px;font-weight:600;z-index:100;opacity:0;transition:.3s;pointer-events:none}
.toast.show{opacity:1}
.empty{color:#aeaeb2;font-size:12px;text-align:center;padding:14px}
.quote{text-align:center;font-size:12px;color:#aeaeb2;font-style:italic;margin:16px 16px 20px;line-height:1.5}

/* Login */
.login{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:30px;text-align:center}
.login h1{font-size:28px;color:#6C5CE7;margin-top:8px}
.login p{font-size:14px;color:#86868b;margin:8px 0 30px;line-height:1.5}
.g-btn{display:flex;align-items:center;gap:10px;background:#fff;border:1.5px solid #d1d1d6;border-radius:12px;padding:14px 28px;font-size:15px;font-weight:600;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,.06);color:#1d1d1f}
.g-btn img{width:20px;height:20px}
.feat{font-size:13px;color:#86868b;padding:6px 0;text-align:left}

/* Onboarding */
.onboard{padding:20px 16px;min-height:100vh}
.ob-title{font-size:22px;font-weight:800;color:#6C5CE7;margin-bottom:4px}
.ob-sub{font-size:13px;color:#86868b;margin-bottom:20px}
.ob-step{font-size:11px;color:#a78bfa;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:12px}
.freq-pills{display:flex;gap:8px;margin-top:4px}
.freq-pill{padding:8px 14px;border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;border:1.5px solid #d1d1d6;color:#86868b;background:#f5f5f7}
.freq-pill.on{background:#6C5CE7;color:#fff;border-color:#6C5CE7}
.task-preview{display:flex;align-items:center;gap:10px;padding:10px;background:#f5f5f7;border-radius:10px;margin-top:8px}
.task-preview .name{flex:1;font-size:13px;font-weight:600}
.task-preview .freq{font-size:10px;color:#fff;background:#6C5CE7;padding:2px 8px;border-radius:10px}
.task-preview .del{color:#FF3B30;font-size:18px;cursor:pointer;padding:0 6px}

/* App Shell */
.app{padding:12px 12px 120px}
.hdr{background:linear-gradient(135deg,#6C5CE7,#a78bfa);border-radius:16px;padding:16px 20px;margin-bottom:14px;color:#fff;display:flex;align-items:center;gap:14px}
.av{width:40px;height:40px;border-radius:50%;border:2px solid rgba(255,255,255,.3);object-fit:cover}
.hdr .info{flex:1}
.hdr .lbl{font-size:10px;text-transform:uppercase;letter-spacing:2px;opacity:.7}
.hdr .nm{font-size:18px;font-weight:800;margin-top:1px}
.hdr .stk{font-size:12px;opacity:.85;margin-top:3px}
.so{background:rgba(255,255,255,.2);border:none;color:#fff;border-radius:8px;padding:6px 12px;font-size:11px;font-weight:600;cursor:pointer}
.tabs{display:flex;background:#fff;border-radius:12px;padding:3px;margin-bottom:14px;box-shadow:0 1px 3px rgba(0,0,0,.08)}
.tb{flex:1;text-align:center;padding:9px 4px;font-size:11px;font-weight:600;color:#86868b;border-radius:10px;cursor:pointer;border:none;background:none}
.tb.on{background:#6C5CE7;color:#fff;box-shadow:0 2px 8px rgba(108,92,231,.3)}
.dn{display:flex;align-items:center;justify-content:space-between;background:#fff;border-radius:12px;padding:10px 16px;margin-bottom:14px;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.dn button{background:none;border:none;color:#6C5CE7;font-size:24px;cursor:pointer;padding:4px 12px;font-weight:700}
.locked-msg{background:#FFF3CD;color:#856404;font-size:12px;padding:10px 14px;border-radius:10px;text-align:center;margin-bottom:12px;font-weight:600}

/* Tasks */
.rw{display:flex;align-items:flex-start;gap:12px;padding:12px 0;border-bottom:1px solid #f0f0f2;cursor:pointer;-webkit-tap-highlight-color:transparent}
.rw:last-child{border-bottom:none}
.ck{width:24px;height:24px;border:2.5px solid #d1d1d6;border-radius:7px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:#fff;margin-top:1px;transition:.15s}
.ck.on{background:#34C759;border-color:#34C759}
.tn{font-size:14px;font-weight:600;color:#1d1d1f}
.td2{font-size:11px;color:#86868b;margin-top:2px}
.rw.dn3 .tn{opacity:.45;text-decoration:line-through}
.rw.dn3 .td2{opacity:.3}
.nb{display:flex;align-items:center;gap:8px;margin-top:6px;padding:6px 10px;background:#f5f5f7;border-radius:8px}
.nb span{font-size:11px;color:#86868b;flex:1}
.nb input{width:54px;background:#fff;border:1.5px solid #d1d1d6;border-radius:6px;color:#1d1d1f;font-size:14px;padding:5px 8px;text-align:center}
.nb input:focus{border-color:#6C5CE7;outline:none}
.freq-tag{font-size:9px;color:#6C5CE7;background:#EDE7F6;padding:2px 6px;border-radius:6px;font-weight:700;margin-left:6px;text-transform:uppercase}

/* Submit */
.sub-wrap{position:sticky;bottom:12px;z-index:10}
.sub-btn{width:100%;background:linear-gradient(135deg,#34C759,#30B350);color:#fff;border:none;border-radius:14px;padding:16px;font-size:16px;font-weight:800;cursor:pointer;box-shadow:0 4px 15px rgba(52,199,89,.35)}
.sub-btn:active{transform:scale(.97)}
.sub-btn.saved{background:linear-gradient(135deg,#6C5CE7,#a78bfa)}
.sub-btn:disabled{opacity:.6}

/* Calendar */
.cg{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;margin-top:8px}
.cg .ch{font-size:10px;color:#86868b;text-align:center;padding:4px;font-weight:600}
.cy{aspect-ratio:1;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;cursor:pointer;background:#f5f5f7;color:#aeaeb2}
.cy.pf{background:#34C759;color:#fff}
.cy.pt{background:#E8F5E9;color:#2E7D32}
.cy.now{outline:2.5px solid #6C5CE7;outline-offset:-1px}
.mn{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.mn button{background:none;border:none;color:#6C5CE7;font-size:20px;cursor:pointer;padding:4px 10px;font-weight:700}

/* Rewards */
.rew-banner{background:linear-gradient(135deg,#FFD700,#FFA500);border-radius:14px;padding:20px;margin-bottom:12px;text-align:center;color:#1d1d1f;box-shadow:0 2px 12px rgba(255,165,0,.25)}
.rew-code{background:#fff;border-radius:8px;padding:10px;margin-top:10px;font-size:20px;font-weight:800;color:#6C5CE7;letter-spacing:3px;font-family:monospace}
.pbar{background:#f5f5f7;border-radius:10px;height:12px;margin-top:14px;overflow:hidden}
.pfill{background:linear-gradient(90deg,#6C5CE7,#a78bfa);height:100%;border-radius:10px}
.ms{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid #f0f0f2}
.ms:last-child{border-bottom:none}
.badge-row{display:flex;gap:6px;flex-wrap:wrap;margin-top:8px}
.badge{font-size:10px;background:#f0f0f2;border-radius:12px;padding:4px 10px;color:#86868b;font-weight:600}
.badge.earned{background:#E8F5E9;color:#2E7D32}
.badge.gold{background:linear-gradient(135deg,#FFD700,#FFA500);color:#1d1d1f}

/* Report */
.sb{background:#f5f5f7;border-radius:10px;padding:14px;text-align:center}
.sb .big{font-size:26px;font-weight:800}
.sb .sm{font-size:10px;color:#86868b;margin-top:2px}
</style>
</head>
