function showObStep2(){
  var root=document.getElementById("root");
  var html='<div class="onboard"><div class="ob-step">Step 2 of 2</div><div class="ob-title">Create Your Tasks</div><div class="ob-sub">Add the habits and tasks you want to track. You can always edit later.</div>';

  // Add task form
  html+='<div class="card"><div class="card-t">&#10010; Add a Task or Project</div>';
  html+='<div class="freq-pills" style="margin-bottom:12px"><span class="freq-pill on" data-m="task">&#9998; Task</span><span class="freq-pill" data-m="project">&#128197; Project</span></div>';

  // Task form
  html+='<div id="taskForm"><label style="margin-top:0">Task Name</label>';
  html+='<input id="atName" placeholder="e.g. Workout, Read 30 min, Cold outreach...">';
  html+='<label>Description (optional)</label>';
  html+='<input id="atDesc" placeholder="Brief description">';
  html+='<label>Frequency</label>';
  html+='<div class="freq-pills"><span class="freq-pill on" data-f="daily">Daily</span><span class="freq-pill" data-f="weekly">Weekly (Mon)</span><span class="freq-pill" data-f="monthly">Monthly (1st)</span><span class="freq-pill" data-f="custom">Every X days</span></div>';
  html+='<div id="customDaysWrap" style="display:none;margin-top:8px"><label>Repeat every how many days?</label><input id="atCustomDays" type="number" min="2" max="90" placeholder="e.g. 3 = every 3rd day" value="3"></div>';
  html+='<label>Track a number? (optional)</label>';
  html+='<input id="atNum" placeholder="e.g. Responses received, Pages read...">';
  html+='<div style="margin-top:12px"><button class="btn btn-purple btn-small" id="atAdd">+ Add Task</button></div></div>';

  // Project form
  html+='<div id="projForm" style="display:none"><label style="margin-top:0">Project Name</label>';
  html+='<input id="apName" placeholder="e.g. Pitch Deck for Startup X, Revit Model...">';
  html+='<label>Description (optional)</label>';
  html+='<input id="apDesc" placeholder="What is this project about?">';
  html+='<label>Total Hours Needed</label>';
  html+='<input id="apHours" type="number" min="1" max="500" placeholder="e.g. 20">';
  html+='<label>Deadline</label>';
  html+='<input id="apDeadline" type="date" min="'+fm(new Date())+'">';
  html+='<div style="background:#f5f5f7;border-radius:10px;padding:10px;margin-top:8px;font-size:12px;color:#86868b" id="projCalc"></div>';
  html+='<div style="margin-top:12px"><button class="btn btn-green btn-small" id="apAdd">+ Add Project</button></div></div>';

  html+='</div>';

  // Task list
  html+='<div class="card"><div class="card-t">Your Tasks ('+obTasks.length+')</div><div id="obList">';
  if(obTasks.length===0) html+='<div class="empty">No tasks yet. Add at least 1 above.</div>';
  for(var i=0;i<obTasks.length;i++){
    var t=obTasks[i];
    var fLabel=t.freq;
    if(t.freq==="custom") fLabel="Every "+t.customDays+"d";
    if(t.freq==="project") fLabel="Project "+t.totalDays+"d";
    html+='<div class="task-preview"><div class="name">'+es(t.name)+'</div><div class="freq">'+fLabel+'</div><span class="del" data-ri="'+i+'">&#215;</span></div>';
  }
  html+='</div></div>';

  html+='<button class="btn btn-green" id="obDone" style="margin-bottom:20px"'+(obTasks.length===0?" disabled":"")+'>&#10003; Finish Setup &amp; Start Tracking</button>';
  html+='<button style="background:none;border:none;color:#86868b;font-size:13px;cursor:pointer;width:100%;text-align:center;padding:10px" id="obBack">&#8249; Back to Step 1</button>';
  html+='</div>';
  root.innerHTML=html;

  // Mode toggle (Task vs Project)
  var mode="task";
  var modePills=document.querySelectorAll("[data-m]");
  for(var i=0;i<modePills.length;i++) modePills[i].onclick=function(){
    mode=this.dataset.m;
    for(var j=0;j<modePills.length;j++) modePills[j].className="freq-pill"+(modePills[j].dataset.m===mode?" on":"");
    document.getElementById("taskForm").style.display=mode==="task"?"":"none";
    document.getElementById("projForm").style.display=mode==="project"?"":"none";
  };

  // Freq pills
  var selFreq="daily";
  var pills=document.querySelectorAll("[data-f]");
  for(var i=0;i<pills.length;i++) pills[i].onclick=function(){
    selFreq=this.dataset.f;
    for(var j=0;j<pills.length;j++) pills[j].className="freq-pill"+(pills[j].dataset.f===selFreq?" on":"");
    var cw=document.getElementById("customDaysWrap");
    if(cw) cw.style.display=selFreq==="custom"?"":"none";
  };

  // Project calculator
  var apH=document.getElementById("apHours");
  var apD=document.getElementById("apDeadline");
  function calcProj(){
    var hrs=parseInt(apH?apH.value:0)||0;
    var dl=apD?apD.value:"";
    var el=document.getElementById("projCalc");
    if(!el||!hrs||!dl) {if(el) el.textContent="Enter hours and deadline to see plan.";return;}
    var daysNeeded=Math.ceil(hrs/2);
    var daysAvail=Math.ceil((mk(dl)-new Date())/864e5);
    if(daysAvail<=0){el.innerHTML="&#9888; Deadline is in the past!";return;}
    if(daysNeeded>daysAvail){el.innerHTML="&#9888; Not enough time! 
