function pad(n){return n<10?"0"+n:""+n;}
function fm(d){return d.getFullYear()+"-"+pad(d.getMonth()+1)+"-"+pad(d.getDate());}
function td(){return fm(new Date());}
function mk(s){return new Date(s+"T00:00:00");}
function es(s){var d=document.createElement("div");d.textContent=s;return d.innerHTML;}
function ts(m){var t=document.getElementById("toast");t.innerHTML=m;t.classList.add("show");setTimeout(function(){t.classList.remove("show");},2500);}

function getTasksForDate(ds){
  if(!UD||!UD.tasks) return [];
  var dt=mk(ds),dow=dt.getDay(),dom=dt.getDate();
  var result=[];
  for(var i=0;i<UD.tasks.length;i++){
    var t=UD.tasks[i];
    if(t.freq==="daily"){result.push(t);continue;}
    if(t.freq==="weekly"&&dow===1){result.push(t);continue;}
    if(t.freq==="monthly"&&dom===1){result.push(t);continue;}
    if(t.freq==="custom"&&t.startDate&&t.customDays){
      var start=mk(t.startDate);
      var diff=Math.round((dt-start)/864e5);
      if(diff>=0&&diff%t.customDays===0){result.push(t);continue;}
    }
    if(t.freq==="project"&&t.startDate&&t.deadline){
      var pStart=mk(t.startDate);
      var pEnd=mk(t.deadline);
      if(dt>=pStart&&dt<=pEnd){
        var dayNum=getProjDayNum(t,ds);
        if(dayNum>0&&dayNum<=t.totalDays){result.push(t);continue;}
      }
    }
  }
  return result;
}

function getProjDayNum(t,ds){
  // Count working days from start to ds (inclusive)
  var start=mk(t.startDate);
  var target=mk(ds);
  var count=0;
  var d=new Date(start);
  while(d<=target){
    count++;
    if(fm(d)===ds) return count<=t.totalDays?count:0;
    d.setDate(d.getDate()+1);
  }
  return 0;
}
function cntDone(obj,ds){
  var tasks=getTasksForDate(ds),done=0,total=tasks.length;
  for(var i=0;i<tasks.length;i++) if(obj[tasks[i].id]) done++;
  return{done:done,total:total};
}

