// ── ONBOARDING ───────────────────────────────────
var obTasks=[];
var obStep=1;

function showOnboarding(){
  if(obStep===1) showObStep1();
  else showObStep2();
}

function showObStep1(){
  var root=document.getElementById("root");
  var html='<div class="onboard"><div class="ob-step">Step 1 of 2</div><div class="ob-title">Welcome! Tell us about you</div><div class="ob-sub">This helps us personalize your experience.</div>';
  html+='<div class="card"><label style="margin-top:0">Your Name</label>';
  html+='<input id="obName" placeholder="Enter your full name" value="'+(U.displayName||"")+'">';
